  font-size: 20px;
  color: #8C5A2B;
  font-weight: 500;
}

.form-container {
  background-color: #FFFFFF;
  border-radius: 16px;
  padding: 30px 24px;
  border: 1px solid #C6A664;
  box-shadow: 0 4px 12px rgba(74, 46, 27, 0.08);
}

.input-group {
  margin-bottom: 24px;
}

.label {
  font-size: 15px;
  font-weight: bold;
  color: #4A2E1B;
  margin-bottom: 10px;
}

.input {
  height: 48px;
  background-color: #F6EFE9;
  border-radius: 12px;
  padding: 0 16px;
  font-size: 16px;
  border: 1px solid #C6A664;
  color: #4A2E1B;
}

.login-btn-custom {
  margin-top: 20px;
}

.action-links {
  margin-top: 20px;
  align-items: center;
}

.link-text {
  font-size: 14px;
  color: #8C5A2B;
  text-decoration: underline;
  font-weight: 500;
}

.wechat-login {
  margin-top: 30px;
  align-items: center;
  border-top: 1px solid #E8DCC8;
  padding-top: 20px;
}

.wechat-btn {
  background-color: transparent;
  font-size: 15px;
  color: #248A22;
  font-weight: 500;
  text-decoration: underline;
  border: none;
}
.wechat-btn::after {
  border: none;
}
</style>

import type { ChatMessage } from '../types/ai.uts'
import { request } from '../utils/request.uts'
import { getMockAIResponse as getMockResponse } from './mock/ai.uts'

/**
 * 发送消息给 AI
 */
export async function sendMessageToAI(
  messages: ChatMessage[], 
  newMessage: string, 
  imageUrl?: string,
  onUpdate?: (chunk: string) => void
): Promise<ChatMessage> {
  const isStream = !!onUpdate
  
  // 如果是流式，我们目前在 request 中很难直接支持（因为 request 返回 Promise<T>）
  // 但我们可以尝试调用 request，如果失败会自动返回 mock
  if (!isStream) {
    return request<ChatMessage>({
      url: '/api/ai/chat/send',
      method: 'POST',
      data: { messages, newMessage, imageUrl }
    })
  }

  // 流式逻辑保持原样，但移除硬编码的 Mock 标签
  return new Promise((resolve) => {
    const apiUrl = 'https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions'
    const apiKey = 'YOUR_API_KEY'

    const requestTask = uni.request({
      url: apiUrl,
      method: 'POST',
      header: {
        'Authorization': `Bearer ${apiKey}`,
        'Content-Type': 'application/json'
      },
      data: {
        model: 'qwen-vl-plus',
        messages: [{ role: 'user', content: newMessage }],
        stream: true
      },
      enableChunked: true,
      success: (res) => {
        if (res.statusCode < 200 || res.statusCode >= 300) {
          resolve(getMockResponse(newMessage, !!imageUrl))
        }
      },
      fail: () => {
        resolve(getMockResponse(newMessage, !!imageUrl))
      }
    })

    let responseText = ''
    requestTask.onChunkReceived((res) => {
      const arrayBuffer = res.data as ArrayBuffer
      const uint8Array = new Uint8Array(arrayBuffer)
      let chunkStr = String.fromCharCode.apply(null, Array.from(uint8Array))
      try {
        chunkStr = decodeURIComponent(escape(chunkStr))
      } catch (e) {}

      const lines = chunkStr.split('\n')
      for (const line of lines) {
        if (line.startsWith('data: ') && line !== 'data: [DONE]') {
          try {
            const dataObj = JSON.parse(line.substring(6)) as any
            const delta = dataObj.choices?.[0]?.delta?.content as string
            if (delta) {
              responseText += delta
              if (onUpdate) onUpdate(delta)
            }
          } catch (e) {}
        }
      }
    })
  })
}

function getMockAIResponse(newMessage: string, hasImage: boolean): ChatMessage {
  return getMockResponse(newMessage, hasImage)
}

/**
 * 获取聊天历史
 */
export async function fetchChatHistory(): Promise<ChatMessage[]> {
  return request<ChatMessage[]>({
    url: '/api/ai/chat/history'
  })
}

/**
 * 识别古建筑
 */
export async function recognizeArchitecture(imageUrl: string): Promise<string> {
  return request<string>({
    url: '/api/ai/recognition',
    method: 'POST',
    data: { imageUrl }
  })
}

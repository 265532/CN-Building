function getMockMarkers(lat: number, lng: number, category: string): MapMarker[] {
  let filtered = allPlaces
  if (category !== 'all') {
    filtered = allPlaces.filter(p => p.category === category)
  }
  
  return filtered.map(p => {
    return {
      id: p.id,
      latitude: p.latitude,
      longitude: p.longitude,
      title: p.name,
      iconPath: '/static/marker.png',
      width: 32,
      height: 32,
      address: p.address,
      category: p.category,
      callout: {
        content: p.name,
        color: '#FFFFFF',
        fontSize: 14,
        borderRadius: 8,
        bgColor: '#7A5C48',
        padding: 8,
        display: 'BYCLICK'
      }
    } as MapMarker
  })
}

export function fetchNearbyPlaces(latitude: number, longitude: number, category: string = 'all'): Promise<Place[]> {
  return new Promise((resolve) => {
    // 预留真实 API 调用
    uni.request({
      url: 'https://api.example.com/v1/map/places',
      method: 'GET',
      data: { lat: latitude, lng: longitude, category },
      success: (res) => {
        if (res.statusCode >= 200 && res.statusCode < 300) {
          resolve(res.data as Place[])
        } else {
          // 降级处理：使用 Mock 数据
          resolve(getMockPlaces(category))
        }
      },
      fail: () => {
        // 降级处理：网络请求失败时使用 Mock 数据
        resolve(getMockPlaces(category))
      }
    })
  })
}

function getMockPlaces(category: string): Place[] {
  let filtered = allPlaces
  if (category !== 'all') {
    filtered = allPlaces.filter(p => p.category === category)
  }
  return filtered.map(p => {
    return {
      id: p.id,
      name: p.name,
      distance: p.distance,
      address: p.address,
      category: p.category
    } as Place
  })
}

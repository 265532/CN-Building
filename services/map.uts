import type { MapMarker, Place } from '../types/map.uts'

export function fetchMapMarkers(latitude: number, longitude: number, category: string = 'all'): Promise<MapMarker[]> {
  return new Promise((resolve) => {
    // 预留真实 API 调用
    uni.request({
      url: 'https://api.example.com/v1/map/markers',
      method: 'GET',
      data: { lat: latitude, lng: longitude, category },
      success: (res) => {
        if (res.statusCode >= 200 && res.statusCode < 300) {
          resolve(res.data as MapMarker[])
        } else {
          // 降级处理：使用 Mock 数据
          resolve(getMockMarkers(latitude, longitude, category))
        }
      },
      fail: () => {
        // 降级处理：网络请求失败时使用 Mock 数据
        resolve(getMockMarkers(latitude, longitude, category))
      }
    })
  })
}


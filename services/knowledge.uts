import type { KnowledgeNode } from '../types/knowledge.uts'
import { request } from '../utils/request.uts'
import { getMockNodeTitle as getMockTitle } from './mock/knowledge.uts'

/**
 * 获取知识节点详情
 */
export async function fetchKnowledgeNode(id: string): Promise<KnowledgeNode> {
  return request<KnowledgeNode>({
    url: `/api/knowledge/node?id=${id}`
  })
}

/**
 * 获取节点标题 (用于列表展示)
 */
export function getNodeTitle(id: string): string {
  return getMockTitle(id)
}
